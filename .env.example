# Required
TELEGRAM_TOKEN=
# Legacy name is also supported: TELEGRAM_BOT_TOKEN=
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_PATH=

# Optional
BOT_DB_PATH=data/bot.db
WORKSHEET_NAME=
ADMIN_USER_ID=
BOT_ADMIN_IDS=
BOT_CONFIG_FILE=
YANDEX_OAUTH_TOKEN=
YANDEX_NO_MOVE_DIR=/BOT_UPLOADS/no_move/
YANDEX_24H_DIR=/BOT_UPLOADS/24h/
YANDEX_WAREHOUSE_DELAY_DIR=disk:/BOT_UPLOADS/warehouse_delay/
YANDEX_ALLOWED_EXTS=.xlsx,.xls,.zip
YANDEX_MAX_MB=200
WAREHOUSE_DELAY_WORKSHEET_NAME=Выгрузка задержка склада
PUBLIC_BASE_URL=https://anniland.ru
# Публичный телефон на лендинге (оставьте пустым, чтобы не показывать)
PUBLIC_PHONE=
# Абсолютный URL картинки для Open Graph (если пусто — /static/anniland-logo.png)
PUBLIC_OG_IMAGE_URL=
WEB_SECRET_KEY=
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_RATE_LIMIT_PER_MINUTE=20
WEB_MAX_UPLOAD_MB=20
WEB_ADMIN_USERNAME=
WEB_ADMIN_PASSWORD=
WEB_USER_USERNAME=
WEB_USER_PASSWORD=

# Telegram AI assistant (admin-only, optional)
AI_ENABLED=false
AI_PROVIDER=openai
AI_ADMIN_IDS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=30
AI_MAX_CONCURRENT_REQUESTS=1
AI_MAX_FILES_PER_REQUEST=3
AI_MAX_FILE_MB=10
AI_MAX_ROWS_PER_SOURCE=200
AI_MAX_SCAN_ROWS_PER_SOURCE=5000
AI_MAX_CONTEXT_CHARS=12000
AI_MAX_HISTORY_MESSAGES=4
AI_MAX_ANSWER_CHARS=1800
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_MS=750
AI_TEMPERATURE=0.1
AI_SOURCE_CACHE_TTL_SECONDS=300

# Telegram webhook mode (optional; if TELEGRAM_WEBHOOK_URL is empty, bot uses polling)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_LISTEN=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PATH=/tg/webhook
