# Required
TELEGRAM_TOKEN=
# Legacy name is also supported: TELEGRAM_BOT_TOKEN=
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_PATH=

# Optional
BOT_DB_PATH=data/bot.db
WORKSHEET_NAME=
ADMIN_USER_ID=
BOT_ADMIN_IDS=
BOT_CONFIG_FILE=
YANDEX_OAUTH_TOKEN=
YANDEX_NO_MOVE_DIR=/BOT_UPLOADS/no_move/
YANDEX_24H_DIR=/BOT_UPLOADS/24h/
YANDEX_WAREHOUSE_DELAY_DIR=disk:/BOT_UPLOADS/warehouse_delay/
YANDEX_ALLOWED_EXTS=.xlsx,.xls,.zip
YANDEX_MAX_MB=200
WAREHOUSE_DELAY_WORKSHEET_NAME=Выгрузка задержка склада
PUBLIC_BASE_URL=https://AnniLand.ru
WEB_SECRET_KEY=
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_RATE_LIMIT_PER_MINUTE=20
WEB_MAX_UPLOAD_MB=20
WEB_ADMIN_USERNAME=
WEB_ADMIN_PASSWORD=
WEB_USER_USERNAME=
WEB_USER_PASSWORD=

# Telegram webhook mode (optional; if TELEGRAM_WEBHOOK_URL is empty, bot uses polling)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_LISTEN=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PATH=/tg/webhook
